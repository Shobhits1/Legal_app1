// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  badge     String?  @unique // Made optional for OAuth users
  rank      String?
  station   String?
  phone     String?
  password  String?  // Made optional for OAuth users
  role      String   @default("OFFICER")
  isActive  Boolean  @default(true)
  image     String?  // Profile image from OAuth provider
  emailVerified DateTime? // For NextAuth
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  firs      FIR[]      @relation("FIRCreator")
  assignedFirs FIR[]   @relation("FIRAssignee")
  reviewedFirs FIR[]   @relation("FIRReviewer")
  sessions  Session[]
  legacySessions LegacySession[]
  reports   Report[]
  favorites Favorite[]
  accounts  Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Legacy Session model for JWT-based auth (keeping for backward compatibility)
model LegacySession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("legacy_sessions")
}

model FIR {
  id          String    @id @default(cuid())
  firNumber   String    @unique
  title       String
  description String
  incidentDate DateTime
  location    String
  complainant String
  accused     String?
  status      String    @default("DRAFT")
  priority    String    @default("MEDIUM")
  
  // Legal sections (stored as JSON strings)
  primarySections   String
  secondarySections String?
  
  // AI Analysis
  aiAnalysis    String?
  confidence    Float?
  recommendations String?
  
  // Case laws
  relevantCaseLaws String?
  
  // Metadata
  createdBy    String
  assignedTo   String?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  creator   User   @relation("FIRCreator", fields: [createdBy], references: [id])
  assignee  User?  @relation("FIRAssignee", fields: [assignedTo], references: [id])
  reviewer  User?  @relation("FIRReviewer", fields: [reviewedBy], references: [id])
  documents Document[]
  reports   Report[]

  @@map("firs")
}

model LegalSection {
  id          String   @id @default(cuid())
  act         String   // IPC, BNS, etc.
  section     String
  title       String
  description String
  punishment  String
  essentials  String   // JSON string
  category    String
  frequency   String
  relatedSections String // JSON string
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  caseLaws    CaseLawSection[]

  @@unique([act, section])
  @@map("legal_sections")
}

model CaseLaw {
  id          String   @id @default(cuid())
  title       String
  citation    String   @unique
  court       String
  date        DateTime
  category    String
  summary     String
  keyPoints   String   // JSON string
  fullText    String?
  rating      Int      @default(5)
  relevance   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sections    CaseLawSection[]

  @@map("case_laws")
}

model CaseLawSection {
  id           String @id @default(cuid())
  caseLawId    String
  sectionId    String

  caseLaw      CaseLaw      @relation(fields: [caseLawId], references: [id], onDelete: Cascade)
  legalSection LegalSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([caseLawId, sectionId])
  @@map("case_law_sections")
}

model Document {
  id          String       @id @default(cuid())
  firId       String
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  type        String
  uploadedBy  String
  createdAt   DateTime     @default(now())

  // Relations
  fir         FIR          @relation(fields: [firId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Report {
  id          String     @id @default(cuid())
  title       String
  type        String
  data        String     // JSON string
  generatedBy String
  firId       String?
  createdAt   DateTime   @default(now())

  // Relations
  generator   User       @relation(fields: [generatedBy], references: [id])
  fir         FIR?       @relation(fields: [firId], references: [id])

  @@map("reports")
}

model Favorite {
  id        String      @id @default(cuid())
  userId    String
  type      String
  itemId    String
  createdAt DateTime    @default(now())

  // Relations
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, itemId])
  @@map("favorites")
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  String?  // JSON string
  userId    String?
  createdAt DateTime @default(now())

  @@map("system_logs")
}

model VoiceRecording {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  language    String
  transcript  String?
  confidence  Float?
  processedBy String
  createdAt   DateTime @default(now())

  @@map("voice_recordings")
}